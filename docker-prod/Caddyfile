# Production Caddyfile — auto HTTPS via Let's Encrypt

# Explicit HTTP → HTTPS redirect
http://amankayare.com {
	redir https://amankayare.com{uri} permanent
}

# Main Portfolio Domain
{$DOMAIN:amankayare.com} {
	encode zstd gzip
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer-when-downgrade"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-XSS-Protection "1; mode=block"
		-Server
	}

	# Portfolio API
	handle /api/* {
		reverse_proxy backend:5000
	}
	handle /uploads/* {
		reverse_proxy backend:5000
	}
	handle /apidocs/* {
		reverse_proxy backend:5000
	}
	handle /flasgger_static/* {
		reverse_proxy backend:5000
	}

	# Portfolio Frontend
	handle {
		root * /srv
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		try_files {path} /index.html
		file_server
	}
}

# Email Microservice Domain
email.amankayare.com {
    reverse_proxy email-api:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    header {
        Permissions-Policy interest-cohort=()
        Strict-Transport-Security max-age=31536000;
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        -Server
    }
}
