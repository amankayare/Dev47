# Production Environment Variables
# Copy this file to .env and update ALL values before deploying

# ─── Git ─────────────────────────────────────────────────
# Branch or tag to deploy (pulled during docker build)
GIT_BRANCH=main

# ─── Domain ──────────────────────────────────────────────
DOMAIN=amankayare.com

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# ─── Backend ─────────────────────────────────────────────
DATABASE_URL=postgresql://portfolio_user:CHANGE_ME_TO_A_SECURE_PASSWORD@postgres:5432/portfolio
FLASK_ENV=production
FRONTEND_ORIGIN=https://amankayare.com

# ─── Security Keys ───────────────────────────────────────
# IMPORTANT: Generate unique keys before deploying!
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#   openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
ADMIN_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD
